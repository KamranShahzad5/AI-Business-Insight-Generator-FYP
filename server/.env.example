PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/insightify

# Groq API key (Free tier at https://console.groq.com/)
# Get your free API key from Groq console
GROQ_API_KEY=your_actual_groq_api_key_here

# JWT secret for authentication (generate a random string)
JWT_SECRET=your_secret_jwt_key_here_change_in_production

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173